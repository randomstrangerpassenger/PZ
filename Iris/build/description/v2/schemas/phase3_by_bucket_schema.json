{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase3_by_bucket_schema.json",
  "title": "Phase 3 Candidate State By Bucket",
  "type": "object",
  "additionalProperties": false,
  "required": ["buckets"],
  "properties": {
    "buckets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "bucket_id",
          "target_count",
          "reviewed_count",
          "keep_count",
          "promote_count",
          "manual_count",
          "reason_breakdown",
          "profile_breakdown"
        ],
        "properties": {
          "bucket_id": { "type": "string", "minLength": 1 },
          "target_count": { "type": "integer", "minimum": 0 },
          "reviewed_count": { "type": "integer", "minimum": 0 },
          "keep_count": { "type": "integer", "minimum": 0 },
          "promote_count": { "type": "integer", "minimum": 0 },
          "manual_count": { "type": "integer", "minimum": 0 },
          "reason_breakdown": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          },
          "profile_breakdown": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
