{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase3_gaps_schema.json",
  "title": "Phase 3 Candidate State Gaps",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manual_clusters",
    "rule_gap_examples",
    "layer_collision_examples",
    "high_manual_buckets",
    "style_risk_clusters"
  ],
  "properties": {
    "manual_clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason_code", "count", "example_fulltypes"],
        "properties": {
          "reason_code": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 0 },
          "example_fulltypes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "rule_gap_examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fulltype", "bucket_id", "candidate_reason_code", "notes"],
        "properties": {
          "fulltype": { "type": "string", "minLength": 1 },
          "bucket_id": { "type": "string", "minLength": 1 },
          "candidate_reason_code": { "type": "string", "minLength": 1 },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "layer_collision_examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["fulltype", "bucket_id", "candidate_reason_code", "notes"],
        "properties": {
          "fulltype": { "type": "string", "minLength": 1 },
          "bucket_id": { "type": "string", "minLength": 1 },
          "candidate_reason_code": { "type": "string", "minLength": 1 },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "high_manual_buckets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["bucket_id", "manual_count", "target_count", "manual_rate"],
        "properties": {
          "bucket_id": { "type": "string", "minLength": 1 },
          "manual_count": { "type": "integer", "minimum": 0 },
          "target_count": { "type": "integer", "minimum": 0 },
          "manual_rate": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "style_risk_clusters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason_code", "count", "example_fulltypes"],
        "properties": {
          "reason_code": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 0 },
          "example_fulltypes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
