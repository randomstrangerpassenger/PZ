{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "phase3_summary_schema.json",
  "title": "Phase 3 Candidate State Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_target_total",
    "review_closed_total",
    "keep_silent_count",
    "promote_active_count",
    "manual_override_candidate_count",
    "active_rate",
    "manual_rate",
    "reason_code_breakdown",
    "compose_profile_breakdown",
    "invalid_combo_count",
    "snapshot_mismatch_count",
    "determinism_sha"
  ],
  "properties": {
    "review_target_total": { "type": "integer", "minimum": 0 },
    "review_closed_total": { "type": "integer", "minimum": 0 },
    "keep_silent_count": { "type": "integer", "minimum": 0 },
    "promote_active_count": { "type": "integer", "minimum": 0 },
    "manual_override_candidate_count": { "type": "integer", "minimum": 0 },
    "active_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "manual_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason_code_breakdown": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "compose_profile_breakdown": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "invalid_combo_count": { "type": "integer", "minimum": 0 },
    "snapshot_mismatch_count": { "type": "integer", "minimum": 0 },
    "determinism_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
